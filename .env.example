# ─── ETD-XAI Enterprise — environment configuration ───────────────────────────
# Copy to `.env` and adjust. All values have safe defaults; nothing here is
# required for local development.

# Application
APP_NAME=ETD-XAI Enterprise
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Persistence (point these at a persistent volume in production)
DATABASE_PATH=etd_xai.db
MODEL_PATH=uploads/model/cnnlstm_final.keras
DATASET_PATH=uploads/dataset
UPLOAD_FOLDER=uploads

# Optional: auto-process this dataset on first boot (empty DB only)
# BOOTSTRAP_DATASET_PATH=uploads/dataset/datasetsmall (2).csv

# Security
SECRET_KEY=change-me-to-a-long-random-string
MAX_UPLOAD_MB=500
# Comma-separated list of allowed origins ("*" for any)
CORS_ORIGINS=*

# Frontend (build-time): the public URL of the backend API
VITE_API_URL=https://your-domain.com
