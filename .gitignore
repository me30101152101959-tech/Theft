# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.env
.venv/
venv/
dist/
build/
*.log
*.tmp
*.cache

# ── Node ────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/.env.local

# ── Models & datasets ───────────────────────────────────
# Ignore uploaded models/datasets by default, but KEEP the bundled active
# model + sample dataset so the app runs immediately after `git clone`.
backend/uploads/model/*.keras
backend/uploads/model/*.h5
backend/uploads/dataset/*.csv
!backend/uploads/model/cnnlstm_final.keras
!backend/uploads/dataset/datasetsmall (2).csv

# ── SQLite DB (per-deployment; lives on a persistent volume) ─
backend/etd_xai.db
backend/etd_xai.db-wal
backend/etd_xai.db-shm
*.sqlite3

# ── Streamlit app: keep bundled model + sample, ignore runtime DB ─
streamlit_app/etd_xai.db
streamlit_app/etd_xai.db-wal
streamlit_app/etd_xai.db-shm
streamlit_app/uploads/

# ── Logs ────────────────────────────────────────────────
logs/
/var/log/etd-xai/

# ── OS / IDE ────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.user
